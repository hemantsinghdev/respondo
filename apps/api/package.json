{
  "name": "api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts | pino-pretty",
    "build": "esbuild src/server.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\" --format=esm --external:pino-pretty",
    "start": "node --env-file=.env dist/index.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@google/genai": "^1.51.0",
    "@huggingface/inference": "^4.13.15",
    "@repo/auth": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/email": "workspace:*",
    "@repo/jobs": "workspace:*",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "zod": "^4.3.5"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.1",
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
