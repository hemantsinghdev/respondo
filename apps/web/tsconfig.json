{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "types": ["node"],
    "paths": {
      "@app/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "globals.d.ts",
    "next.config.js",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
