# DATABASE_URL for Prisma Tooling
# ------------------------------
# This file is used ONLY by the Prisma CLI within this package.
# It is required for:
# - 'pnpm prisma generate' (to load the schema/config)
# - 'pnpm prisma migrate' (to talk to the DB for changes)
#
# NOTE: Applications use their own local .env files. 
# Ensure the DATABASE_URL is synced across all relevant files if they need to point to the same database.

DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"